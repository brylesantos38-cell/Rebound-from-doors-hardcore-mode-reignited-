entity:SetCallback("OnDamagePlayer", function(newHealth: number)
	if newHealth <= 0 then
		print("Entity has killed the player")
	else
		print("Entity has damaged the player")
		local TweenService = game:GetService("TweenService")

		local model = workspace:WaitForChild("Deer God")
		local part = model.RushNew
		assert(part, "Model chưa có PrimaryPart!")

		local player = game.Players.LocalPlayer
		local hrp = (player.Character or player.CharacterAdded:Wait()):WaitForChild("HumanoidRootPart")

		part.Anchored = true

		local tween = TweenService:Create(
			part,
			TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{CFrame = hrp.CFrame}
		)

		tween:Play()
		tween.Completed:Wait()
	end
end)

