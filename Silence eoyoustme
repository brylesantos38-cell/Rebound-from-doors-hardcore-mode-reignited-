local sound = Instance.new("Sound")
sound.SoundId = "rbxassetid://7861818231"
sound.Volume = 4
sound.Parent = workspace
sound:Play()

task.wait(3)

local lastPos = HRP.Position
local Kill = true
local damageInterval = 0.054

task.spawn(function()
	while Kill do
		task.wait(damageInterval)

		local currentPos = HRP.Position

		if (currentPos-lastPos).Magnitude > 0.3 then

			require(LocalPlayer.PlayerGui.MainUI.Initiator.Main_Game).caption("",true)

			if Humanoid.Health > 0 and not Character:GetAttribute("Crouching") then

				local s = Instance.new("Sound")
				s.SoundId = "rbxassetid://7861818231"
				s.Volume = 4
				s.Parent = workspace
				s:Play()

				local tween = TweenService:Create(
					Silence,
					TweenInfo.new(0.3,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),
					{
						CFrame = HRP.CFrame
					}
				)

				tween:Play()

				if not Character:GetAttribute("Crouching") then
					Humanoid.Health = 0
					local sound = Instance.new("Sound")
					sound.SoundId = "rbxassetid://4988621968"
					sound.Volume = 10
					sound.PlaybackSpeed = 0.7
					sound.Parent = workspace
					sound:Play()
					break
				end
			end
		end

		lastPos = currentPos
	end
end)

local Removed = false

local function RemoveSilence()
	if Removed then
		return
	end

	Removed = true
	Kill = false

	if Silence5 and Silence5.Parent then
		Silence5:Destroy()
	end
end

task.delay(7, RemoveSilence)

local connection
connection = workspace.CurrentRooms.ChildAdded:Connect(function()
	RemoveSilence()

	if connection then
		connection:Disconnect()
	end
end)
